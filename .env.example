# ============================================
# DevFlow Agent 环境配置（模板）
# 复制此文件为 .env 并填入你的真实配置
# cp .env.example .env
# ============================================

# ---------- DeepSeek / OpenAI API ----------
# 必填：你的 API Key（支持 DeepSeek 或任何 OpenAI 兼容接口）
OPENAI_API_KEY=sk-your-api-key-here
# API 地址（默认 DeepSeek，换成 https://api.openai.com/v1 即可用 OpenAI）
OPENAI_BASE_URL=https://api.deepseek.com
# 模型名（deepseek-chat / deepseek-coder / gpt-4o 等）
OPENAI_MODEL=deepseek-chat

# ---------- GitHub Token（可选）----------
# 如果需要自动创建 PR，填入你的 GitHub Personal Access Token
# 权限要求：repo (私有仓库) 或 public_repo (公开仓库)
GITHUB_TOKEN=

# ---------- GitHub Webhook Secret（可选）----------
# 生产环境必填！用于验证 GitHub Webhook HMAC-SHA256 签名
GITHUB_WEBHOOK_SECRET=

# ---------- 登录密码 ----------
# 生产环境务必修改为强密码！
DEVFLOW_ADMIN_PASSWORD=change-me-in-production
DEVFLOW_OPERATOR_PASSWORD=change-me-in-production

# ---------- 数据库 ----------
DB_URL=jdbc:mysql://mysql:3306/devflow_agent?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false
DB_USERNAME=devflow
DB_PASSWORD=devflow123

# ---------- 中间件 ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=devflow123
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=devflow
RABBITMQ_PASSWORD=devflow123
